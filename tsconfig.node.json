{
  "compilerOptions": {
    "skipLibCheck": true,
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "outDir": "./dist/main",
    "rootDir": "./src",
    "declaration": false,
    "sourceMap": false
  },
  "include": ["src/main/**/*", "src/shared/**/*"]
}
